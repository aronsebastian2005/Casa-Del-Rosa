{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://casa-del-rosa-backend.onrender.com/api/:path*"
    },
    {
      "source": "/",
      "destination": "/client/home.html"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/login",
      "destination": "/client/login.html"
    },
    {
      "source": "/register",
      "destination": "/client/register.html"
    },
    {
      "source": "/verify",
      "destination": "/client/verify.html"
    },
    {
      "source": "/forgot",
      "destination": "/client/forgot.html"
    },
    {
      "source": "/reservation",
      "destination": "/client/reservation.html"
    },
    {
      "source": "/request-received",
      "destination": "/client/request-received.html"
    }
  ]
}
